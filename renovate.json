{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "addLabels": ["renovate"],
  "automerge": false,
  "kubernetes": {
    "managerFilePatterns": ["/(^|/)deployment\\.ya?ml$/"]
  },
  "flux": {
    "managerFilePatterns": ["/(?:^|/)gotk-components\\.ya?ml$/"]
  },
  "kustomize": {
    "managerFilePatterns": ["/(^|/)kustomization\\.ya?ml$/"],
    "pinDigests": false
  }
}
